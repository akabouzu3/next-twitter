# ===== Database =====
# App runtime 用のDB接続URL。
# Vercel/Supabase本番では Transaction Pooler のURLを入れる。
DATABASE_URL=

# Prisma CLI / migration 用のDB接続URL。
# Supabaseでは 5432 の direct/session pooler URL を入れる。
DIRECT_URL=

# ===== Auth.js =====
# Auth.jsの署名用secret。openssl rand -base64 32 などで生成する。
AUTH_SECRET=

# Vercelなどプロキシ配下でAuth.jsにhostを信頼させる。本番は true。
AUTH_TRUST_HOST=

# Google OAuth Client ID。
# Google Cloud ConsoleでOAuth clientを作成して取得する。
AUTH_GOOGLE_ID=

# Google OAuth Client Secret。公開・commit禁止。
AUTH_GOOGLE_SECRET=

# ===== App URL =====
# ブラウザ側でも参照できるアプリの公開URL。
# 例: http://localhost:3000 / https://your-app.vercel.app
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# サーバー側で参照するアプリの公開URL。
# NEXT_PUBLIC_APP_ORIGINと同じ値でよい。
APP_ORIGIN=http://localhost:3000

# ===== Supabase =====
# Supabase Project URL。
SUPABASE_URL=

# Supabase anon key。基本は公開クライアント用だが、必要な場面に備えて設定しておく。
SUPABASE_ANON_KEY=

# Supabase service role key。Storage uploadで使用するサーバー専用secret。公開・commit禁止。
SUPABASE_SERVICE_ROLE_KEY=

# 画像アップロード先のSupabase Storage bucket名。
SUPABASE_STORAGE_BUCKET=
