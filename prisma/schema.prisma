generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String  @id @default(cuid())

  // login / identification
  name      String
  username  String  @unique @default(cuid())
  email     String  @unique
  bio       String?
  emailVerified DateTime?    // ✅ Google認証に必要
  image         String?       // ✅ Google認証に必要
  backgroundImage String?    // ✅ 追加
  
  // Credentials用（自前）
  passwordHash  String?

  // Role (default is user)
  role      UserRole @default(USER)



  // relations
  posts     Post[]
  likes     PostLike[]
  following Follow[] @relation("UserFollowing")
  followers Follow[] @relation("UserFollowers")
  // DM: 参加している1対1会話と、自分が送信したメッセージ。
  directConversationParticipants DirectConversationParticipant[]
  sentDirectMessages DirectMessage[] @relation("DirectMessageSender")

  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  viewCount Int      @default(0)
  likeCount Int      @default(0)
  replyCount Int     @default(0)
  engagementScore Int @default(0)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentPostId String?
  parentPost   Post?  @relation("PostReplies", fields: [parentPostId], references: [id], onDelete: Cascade)
  replies      Post[] @relation("PostReplies")

  likes     PostLike[]
  images    PostImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * ▼ ユーザー別タイムライン最適化用 index
   *
   * 対象クエリ：
   *   WHERE userId IN (...)
   *   ORDER BY createdAt DESC, id DESC
   *
   * 効果：
   * - userId で絞り込み
   * - createdAt DESC で並び替え
   * - id DESC で同時刻の順序を安定化
   *
   * → indexの順序とクエリの順序が一致しているため
   *   DB側でソートが不要（高速化）
   *
   * 主な用途：
   * - フォロー中ユーザーのタイムライン取得
   */
  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([parentPostId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([engagementScore(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])


  /**
   * ▼ 全体タイムライン & cursor pagination用 index
   *
   * 対象クエリ：
   *   ORDER BY createdAt DESC, id DESC
   *   cursor: (createdAt, id)
   *
   * 効果：
   * - createdAt + id の並び順をそのまま利用できる
   * - cursor paginationで高速に‘「次ページ」を取得可能
   *
   * 内部的には：
   *   WHERE (createdAt, id) < (?, ?)
   *
   * → OFFSETを使わないため大規模データでも高速
   *
   * 主な用途：
   * - 無限スクロール
   * - 全体の新着投稿一覧
   */
  @@index([createdAt(sort: Desc), id(sort: Desc)])


  /**
   * ▼ cursor pagination用の一意制約（必須）
   *
   * 理由：
   * - Prismaのcursorは「ユニークキー」である必要がある
   * - createdAtだけでは同時刻の投稿があり一意にならない
   *
   * 解決：
   * - createdAt + id の組み合わせで完全一意にする
   *
   * 効果：
   * - cursor paginationが正しく動作する
   * - 同時刻投稿でも順序が崩れない
   *
   * 注意：
   * - sortは指定できない（unique制約の仕様）
   */
  @@unique([createdAt, id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  /**
   * フォロー / フォロワー一覧の cursor pagination 用。
   * - followerId / followingId で絞り込む
   * - createdAt DESC, id DESC で安定ソートする
   * - createdAt + id を一意にして Prisma の複合 cursor に使う
   */
  @@unique([createdAt, id])
  @@index([followerId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([followingId, createdAt(sort: Desc), id(sort: Desc)])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())


  // 同じユーザーが同じ投稿に複数回いいねできないようにする
  @@unique([userId, postId])
  // いいね一覧を cursor pagination で取得するため
  @@unique([createdAt, id])

  // ユーザーのいいね一覧用
  @@index([userId, createdAt(sort: Desc), id(sort: Desc)])
  // 投稿ごとのいいね数・いいね済み判定用
  @@index([postId])
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  url       String
  sortOrder Int      @default(0)

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([postId, sortOrder])
}

model DirectConversation {
  id            String   @id @default(cuid())
  /**
   * 1対1DMの重複防止キー。
   *
   * 2人の userId をソートして連結した値を保存する。
   * A→B と B→A のどちらからDMを開始しても同じ key になるため、
   * unique 制約で同じ2人の会話を1つに集約できる。
   */
  directKey     String   @unique
  /**
   * 会話一覧の並び替え用。
   *
   * メッセージ送信時に最新メッセージの createdAt へ更新し、
   * `/messages` ではこの値の降順で最近動いた会話から表示する。
   */
  lastMessageAt DateTime @default(now())

  // v1 は1対1DMだが、参加者テーブルを分けて将来の拡張余地を残す。
  participants DirectConversationParticipant[]
  messages     DirectMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * DM一覧用 index。
   *
   * ORDER BY lastMessageAt DESC, id DESC の安定順で取得するため、
   * 同時刻の会話があっても id で順序を固定できる。
   */
  @@index([lastMessageAt(sort: Desc), id(sort: Desc)])
}

model DirectConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  // v1では未読表示をしないが、既読・未読バッジ拡張用に保持する。
  lastReadAt DateTime?

  // 同じ会話に同じユーザーが重複参加しないようにする。
  @@unique([conversationId, userId])
  // 現在ユーザーが参加している会話一覧を引くための index。
  @@index([userId])
}

model DirectMessage {
  id             String @id @default(cuid())
  conversationId String
  senderId       String
  content        String

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  /**
   * メッセージ一覧・将来のcursor pagination用。
   *
   * createdAt だけでは同時刻のメッセージがあり得るため、
   * id と組み合わせて一意な並び順を作る。
   */
  @@unique([createdAt, id])
  // 会話詳細で、会話ごとのメッセージを時系列に取得するための index。
  @@index([conversationId, createdAt(sort: Desc), id(sort: Desc)])
  // 送信者基準の集計・管理用途に備えた index。
  @@index([senderId])
}
